---
layout: base.njk
---

{# ============================================================
   projet.njk — Page de détail d'un projet
   Ce layout est utilisé par projets.njk (pagination Eleventy).
   La variable "projet" est l'objet du fichier JSON du projet.
   Toutes les données sont affichées, avec des {% if %} pour
   les champs optionnels — c'est ça la logique conditionnelle.
   ============================================================ #}
<a href="{{ '/' | url }}">← Retour</a>
<article>
  {# ── Champs toujours présents ─────────────────────────── #}
  <h1>{{ projet.titre }}</h1>
  <p>
    <strong>Type de mandat :</strong>
    {{ projet.type }}
  </p>
  {# ── Sessions : tableau → on boucle #}
  {% if projet.sessions and projet.sessions.length %}
    <p>
      <strong>Sessions :</strong>
      {{ projet.sessions | join(", ") }}
    </p>
  {% endif %}
  {# ── Clients : champ texte simple ─────────────────────── #}
  {% if projet.clients %}
    <p>
      <strong>Client·e·s :</strong>
      {{ projet.clients }}
    </p>
  {% endif %}
  {# ── Description ──────────────────────────────────────── #}
  {% if projet.description %}
    <p>{{ projet.description | nl2br | safe }}</p>
  {% endif %}
  {# ── Stagiaires par session ───────────────────────────── #}
  {# On définit les 3 sessions et leur clé dans l'objet projet #}
  {%
    set sessions_stagiaires = [
      { label: "Août – décembre",  liste: projet.stagiaires_aout_decembre },
      { label: "Janvier – avril",  liste: projet.stagiaires_janvier_avril },
      { label: "Avril – juillet",  liste: projet.stagiaires_avril_juillet }
    ]
  %}
  {# Condition : on n'affiche le bloc que si au moins une session a des stagiaires #}
  {% set a_des_stagiaires = false %}
  {% for s in sessions_stagiaires %}
    {% if s.liste and s.liste.length %}
      {% set a_des_stagiaires = true %}
    {% endif %}
  {% endfor %}
  {% if a_des_stagiaires %}
    <section>
      <h2>Stagiaires</h2>
      {% for session in sessions_stagiaires %}
        {% if session.liste and session.liste.length %}
          <h3>{{ session.label }}</h3>
          <ul>
            {% for nom in session.liste %}
              <li>{{ nom }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      {% endfor %}
    </section>
  {% endif %}
  {# ── Images : tableau d'objets { fichier, legende } ──── #}
  {% if projet.images and projet.images.length %}
    <section>
      <h2>Images</h2>
      {% for image in projet.images %}
        <figure>
          <img
            src="{{ image.fichier | url }}"
            alt="{{ image.legende or projet.titre }}"
          />
          {# Condition : légende affichée uniquement si renseignée #}
          {% if image.legende %}
            <figcaption>{{ image.legende }}</figcaption>
          {% endif %}
        </figure>
      {% endfor %}
    </section>
  {% endif %}
  {# ── Vidéos : tableau d'objets { url } ───────────────── #}
  {% if projet.videos and projet.videos.length %}
    <section>
      <h2>Vidéos</h2>
      <ul>
        {% for video in projet.videos %}
          <li>
            <a href="{{ video.url }}" target="_blank">{{ video.url }}</a>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}
  {# ── Compétences : champ texte simple ────────────────── #}
  {% if projet.competences %}
    <p>
      <strong>Compétences :</strong>
      {{ projet.competences }}
    </p>
  {% endif %}
  {# ── Liens : tableau d'objets { label, url } ─────────── #}
  {% if projet.liens and projet.liens.length %}
    <section>
      <h2>Liens</h2>
      <ul>
        {% for lien in projet.liens %}
          <li>
            <a href="{{ lien.url }}" target="_blank">
              {# Condition : on affiche le libellé s'il existe, sinon l'URL brute #}
              {{ lien.label if lien.label else lien.url }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}
  {# ── Témoignage client : objet { phrase, nom, role } ─── #}
  {# Condition : on n'affiche le bloc que si la citation est renseignée #}
  {% if projet.retour_client and projet.retour_client.phrase %}
    <blockquote>
      <p>{{ projet.retour_client.phrase }}</p>
      <footer>
        {# Condition imbriquée : nom et rôle sont optionnels #}
        {% if projet.retour_client.nom %}
          <strong>{{ projet.retour_client.nom }}</strong>
        {% endif %}
        {% if projet.retour_client.role %}
          <span>, {{ projet.retour_client.role }}</span>
        {% endif %}
      </footer>
    </blockquote>
  {% endif %}
</article>
{% block scripts %}
  <script type="module" src="{{ '/assets/js/projet.js' | url }}"></script>
{% endblock %}
